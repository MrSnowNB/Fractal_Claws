# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.pyo

# Agent output artifacts — do not commit generated files from runs
output/*.py
output/*.txt
output/*.json
output/*.csv
output/*.log
# Keep the output/ directory itself tracked (via .gitkeep if empty)
!output/.gitkeep

# Logs — session data stays local
logs/*.log
logs/*.jsonl
logs/*-result.txt
!logs/.gitkeep

# Tickets — work surface is ephemeral
tickets/open/*.yaml
tickets/in_progress/*.yaml
tickets/failed/*.yaml
# closed/ tickets committed intentionally for memory promotion
# tickets/closed/*.yaml — NOT ignored, closed tickets are institutional memory

# Experiments — runtime dirs only, source files are tracked
experiments/daemon/logs/
experiments/daemon/inbox/
experiments/daemon/outbox/
*.pid

# Environment
.env
*.env

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
*.swp
*.swo
