# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.pyo

# Agent output artifacts — do not commit generated files from runs
output/*.py
output/*.txt
output/*.json
output/*.csv
output/*.log
# Keep the output/ directory itself tracked (via .gitkeep if empty)
!output/.gitkeep

# Logs — session data stays local
logs/*.log
logs/*.jsonl
logs/*-result.txt
!logs/.gitkeep

# Tickets
# open/   — tracked: Cline writes and pushes tickets here as durable work items
# closed/ — tracked: institutional memory, promoted after drain
# failed/ — NOT tracked: ephemeral failure state, runner-managed
# in_progress/ — NOT tracked: ephemeral runner lock state
tickets/in_progress/*.yaml
tickets/failed/*.yaml

# Experiments — runtime dirs only, source files are tracked
experiments/daemon/logs/
experiments/daemon/inbox/
experiments/daemon/outbox/
*.pid

# Environment
.env
*.env

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
*.swp
*.swo
